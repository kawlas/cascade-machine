# ═══════════════════════════════════════════════════════════════
# CASCADE MACHINE — API Keys Configuration (SZABLON)
# 
# HOW TO USE:
# 1. Skopiuj ten plik: cp ~/.cascade/.env.cascade ~/.cascade/.env
# 2. Wpisz swoje API keys do ~/.cascade/.env (nie do tego pliku!)
# 3. NIE commituj .env do git (jest w .gitignore)
# 4. Załaduj: source ~/.cascade/.env
#
# FREE REGISTRATION LINKS:
# OpenRouter:  https://openrouter.ai/keys
# Groq:        https://console.groq.com/keys
# Cerebras:    https://cloud.cerebras.ai
# Google AI:   https://aistudio.google.com/app/apikey
# x.ai:        https://console.x.ai
# NVIDIA NIM:  (Nemotron 3 Super + other NIM models)
# ═══════════════════════════════════════════════════════════════

# OpenRouter — 29 free models, ~200 req/day free
export OPENROUTER_API_KEY=""

# Groq — llama-3.3-70b, ~800 req/day free (fastest cloud)
export GROQ_API_KEY=""

# Cerebras — llama-3.3-70b, ~150 req/day free (2000 tok/s!)
export CEREBRAS_API_KEY=""

# Google AI Studio — gemini-2.0-flash, ~1500 req/day free
export GEMINI_API_KEY=""

# x.ai — grok-3-mini, $25/month free credits
export XAI_API_KEY=""

# NVIDIA NIM — Nemotron 3 Super (direct NIM endpoint)
export NIM_API_KEY=""

# Cline/Roo-Code (optional)
export CLAUDE_API_KEY=""

# Ollama config (usually no changes needed)
export OLLAMA_HOST="http://localhost:11434"

# Router policy
# Dynamic catalog refreshes provider model lists and prefers free/prepaid cloud.
export CASCADE_MODEL_FAILURE_COOLDOWN="2"
export CASCADE_MODEL_CATALOG_AUTO_REFRESH="true"
export CASCADE_MODEL_CATALOG_TTL_SECONDS="21600"
export CASCADE_MODEL_HEALTH_ENABLED="true"
export CASCADE_MODEL_HEALTH_TTL_SECONDS="900"
export CASCADE_MODEL_HEALTH_PROBE_LIMIT="5"
export CASCADE_MODEL_PROVIDERS="openrouter,groq,gemini,cerebras,xai"
export CASCADE_CLOUD_FREE_ONLY="true"
export CASCADE_PREFERRED_PROVIDER="openrouter"
export CASCADE_OPENROUTER_PREFERRED_FREE_MODELS="openrouter/nvidia/nemotron-3-super-120b-a12b:free,openrouter/arcee-ai/trinity-large-preview:free,openrouter/openrouter/free,openrouter/qwen/qwen3-coder-next,openrouter/stepfun/step-3.5-flash:free,openrouter/minimax/minimax-m2.5:free"

# Local fallback only. Cloud models come from provider APIs.
export CASCADE_REASON_MODELS="ollama_chat/deepseek-r1:8b,ollama_chat/qwen3:4b"
export CASCADE_CODE_MODELS="ollama_chat/qwen3-coder,ollama_chat/devstral-small,ollama_chat/qwen3:4b"
export CASCADE_REFACTOR_MODELS="$CASCADE_CODE_MODELS"
export CASCADE_TEST_MODELS="$CASCADE_CODE_MODELS"
export CASCADE_QUICK_MODELS="ollama_chat/qwen3:4b,ollama_chat/qwen3-coder,ollama_chat/devstral-small"

# Custom provider examples (OpenAI-compatible)
# 1. Add provider name to CASCADE_MODEL_PROVIDERS, eg:
#    export CASCADE_MODEL_PROVIDERS="openrouter,groq,gemini,cerebras,xai,chutes"
# 2. Set base URL, key variable, and tier (`free`, `prepaid`, `paid`)
#
# export CHUTES_API_KEY=""
# export CASCADE_PROVIDER_CHUTES_BASE_URL="https://llm.chutes.ai/v1"
# export CASCADE_PROVIDER_CHUTES_TIER="prepaid"
# export CASCADE_PROVIDER_CHUTES_HEALTHCHECK="true"
#
# NVIDIA NIM (Nemotron 3 Super) example:
# export CASCADE_MODEL_PROVIDERS="openrouter,groq,gemini,cerebras,xai,nim"
# export CASCADE_PROVIDER_NIM_BASE_URL="https://<your-nim-endpoint>/v1"
# export CASCADE_PROVIDER_NIM_MODELS_URL="https://<your-nim-endpoint>/v1/models"
# export CASCADE_PROVIDER_NIM_TIER="prepaid"
# export CASCADE_PROVIDER_NIM_HEALTHCHECK="true"
#
# Another example for a temporary OpenAI-compatible provider:
# export MYCHINA_API_KEY=""
# export CASCADE_PROVIDER_MYCHINA_BASE_URL="https://api.example.com/v1"
# export CASCADE_PROVIDER_MYCHINA_TIER="prepaid"

# Aider defaults
export AIDER_MODEL="ollama_chat/qwen3-coder"
